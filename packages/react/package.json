{
  "name": "@org.ai/react",
  "version": "0.1.0",
  "description": "React SDK for id.org.ai — Agent-First Identity",
  "author": "headless.ly",
  "homepage": "https://id.org.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-org-ai/id.org.ai",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/dot-org-ai/id.org.ai/issues"
  },
  "keywords": [
    "identity",
    "auth",
    "oauth",
    "pkce",
    "react",
    "agent",
    "id.org.ai",
    "headlessly"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "!src/**/*.test.*"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
